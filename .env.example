# Copy to .env and fill in. NEVER commit your real .env or API key.
# Origin provides a temporary, capped key for the synthetic data only.

# Required for the LLM-backed triage path. If unset, the agent runs a
# deterministic fallback so a valid output.json is still produced.
ANTHROPIC_API_KEY=

# Optional. Defaults to claude-opus-4-8 (current top-tier production model).
# Use claude-sonnet-4-6 for cheaper/faster runs. Model choice is not part of
# the rubric. Avoid claude-fable-5 (suspended for export controls).
ANTHROPIC_MODEL=claude-opus-4-8
